{% extends 'base.html.twig' %}

{% block title %}{{ 'demo.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container py-5">
    <h1>{{ 'demo.page_title'|trans({}, 'messages') }}</h1>
    <p class="lead">{{ 'demo.lead'|trans({}, 'messages') }}</p>

    <ul class="list-group list-group-flush">
        <li class="list-group-item">
            <a href="{{ path('app_demo_grid', { _locale: app.request.locale }) }}">{{ 'demo.label_icon_grid'|trans({}, 'messages') }}</a>
            <span class="text-muted small"> — {{ 'demo.page_grid_lead'|trans({}, 'messages') }}</span>
        </li>
        <li class="list-group-item">
            <a href="{{ path('app_demo_search', { _locale: app.request.locale }) }}">{{ 'demo.label_icon_search'|trans({}, 'messages') }}</a>
            <span class="text-muted small"> — {{ 'demo.page_search_lead'|trans({}, 'messages') }}</span>
        </li>
        <li class="list-group-item">
            <a href="{{ path('app_demo_tom_select', { _locale: app.request.locale }) }}">{{ 'demo.label_icon_tom_select'|trans({}, 'messages') }}</a>
            <span class="text-muted small"> — {{ 'demo.page_tom_select_lead'|trans({}, 'messages') }}</span>
        </li>
        <li class="list-group-item">
            <a href="{{ path('app_demo_heroicons', { _locale: app.request.locale }) }}">{{ 'demo.label_icon_heroicons'|trans({}, 'messages') }}</a>
            <span class="text-muted small"> — {{ 'demo.page_heroicons_lead'|trans({}, 'messages') }}</span>
        </li>
    </ul>
</div>
{% endblock %}
