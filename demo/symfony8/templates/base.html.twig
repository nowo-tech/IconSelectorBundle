<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Icon Selector Demo{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    {% set _locale = app.request.locale %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home', { _locale: _locale }) }}">{{ 'demo.title'|trans({}, 'messages') }}</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#demoNavbar" aria-controls="demoNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="demoNavbar">
                {% set _current_route = app.request.attributes['_route'] ?? 'app_home' %}
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link {{ _current_route == 'app_home' ? 'active' : '' }}" href="{{ path('app_home', { _locale: _locale }) }}">{{ 'demo.menu_home'|trans({}, 'messages') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ _current_route == 'app_demo_grid' ? 'active' : '' }}" href="{{ path('app_demo_grid', { _locale: _locale }) }}">{{ 'demo.label_icon_grid'|trans({}, 'messages') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ _current_route == 'app_demo_search' ? 'active' : '' }}" href="{{ path('app_demo_search', { _locale: _locale }) }}">{{ 'demo.label_icon_search'|trans({}, 'messages') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ _current_route == 'app_demo_tom_select' ? 'active' : '' }}" href="{{ path('app_demo_tom_select', { _locale: _locale }) }}">{{ 'demo.label_icon_tom_select'|trans({}, 'messages') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ _current_route == 'app_demo_heroicons' ? 'active' : '' }}" href="{{ path('app_demo_heroicons', { _locale: _locale }) }}">{{ 'demo.label_icon_heroicons'|trans({}, 'messages') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ _current_route == 'app_demo_background' ? 'active' : '' }}" href="{{ path('app_demo_background', { _locale: _locale }) }}">{{ 'demo.page_background_title'|trans({}, 'messages') }}</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="localeDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">{{ _locale == 'es' ? 'Español' : 'English' }}</a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="localeDropdown">
                            <li><a class="dropdown-item {{ _locale == 'en' ? 'active' : '' }}" href="{{ path(_current_route, { _locale: 'en' }) }}">English</a></li>
                            <li><a class="dropdown-item {{ _locale == 'es' ? 'active' : '' }}" href="{{ path(_current_route, { _locale: 'es' }) }}">Español</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    {% block body %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
